generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String    @id @default(uuid())
  name      String
  proxy     String
  apps      App[]
  accounts  Account[]
}

model App {
  id        String   @id @default(uuid())
  name      String
  token     String  
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
}

model Account {
  id        String   @id @default(uuid())
  actId     String   @unique
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  pages     Page[]
  pixels    Pixel[]
}

model Page {
  id        String   @id @default(uuid())
  name      String
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
}

model Pixel {
  id        String   @id @default(uuid())
  name      String
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
}

model Draft {
  id             String   @id @default("singleton") 
  payload        Json
  mediaId        String?
  idempotencyKey String?                            
  updatedAt      DateTime @updatedAt
}

model Job {
  idempotencyKey String   @id          
  jobId          String   @unique
  status         String                
  createdAt      DateTime @default(now())
}